{
  "name": "kekule-svelte",
  "version": "0.1.0",
  "description": "Svelte 5 wrapper for Kekule.js — render and edit organic compound structures from SMILES strings",
  "keywords": [
    "svelte",
    "kekule",
    "chemistry",
    "cheminformatics",
    "smiles",
    "molecular",
    "organic-chemistry",
    "chemical-structure",
    "svelte5",
    "runes"
  ],
  "homepage": "https://kekule-svelte.makeez.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/makeez-labs/kekule-svelte.git"
  },
  "bugs": {
    "url": "https://github.com/makeez-labs/kekule-svelte/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Makeez Labs",
    "url": "https://makeez.dev"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "svelte-package -i src/lib",
    "prepublishOnly": "bun run build",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "svelte-check --tsconfig tsconfig.json",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,svelte}\""
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@testing-library/svelte": "^5.3.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-plugin-svelte": "^3.17.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
